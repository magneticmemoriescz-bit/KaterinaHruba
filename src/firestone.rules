rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for validating common types and IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidDate(dateStr) {
      return dateStr is string && dateStr.size() == 10 && dateStr.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isValidTime(timeStr) {
      return timeStr is string && timeStr.size() == 5 && timeStr.matches('^\\d{2}:\\d{2}$');
    }

    // Default deny catch-all for any other collections
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Bookings Collection Rules
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isValidBooking(request.resource.data);
      allow update: if isValidBooking(request.resource.data);
      allow delete: if true;

      function isValidBooking(data) {
        return data.keys().hasAll([
          'serviceId', 'date', 'startTime', 'endTime', 
          'clientName', 'clientSurname', 'clientPhone', 
          'clientEmail', 'createdAt'
        ])
        && data.serviceId is string && data.serviceId.size() <= 100
        && isValidDate(data.date)
        && isValidTime(data.startTime)
        && isValidTime(data.endTime)
        && data.clientName is string && data.clientName.size() <= 100
        && data.clientSurname is string && data.clientSurname.size() <= 100
        && data.clientPhone is string && data.clientPhone.size() <= 30
        && data.clientEmail is string && data.clientEmail.size() <= 150
        && data.createdAt is string && data.createdAt.size() <= 50
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000));
      }
    }

    // 2. Available Days Collection Rules
    match /available_days/{dayId} {
      allow read: if true;
      allow create: if isValidAvailableDay(request.resource.data);
      allow update: if isValidAvailableDay(request.resource.data);
      allow delete: if true;

      function isValidAvailableDay(data) {
        return data.keys().hasAll(['date', 'activeTimes'])
        && isValidDate(data.date)
        && data.activeTimes is list
        && data.activeTimes.size() <= 100
        && (data.activeTimes.size() == 0 || (data.activeTimes[0] is string && data.activeTimes[0].size() == 5))
        && (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 50));
      }
    }

    // 3. Contact Messages Collection Rules
    match /messages/{messageId} {
      allow read: if true; // Allowed for admin viewing if needed
      allow create: if isValidMessage(request.resource.data);
      allow delete: if true;

      function isValidMessage(data) {
        return data.keys().hasAll(['name', 'email', 'phone', 'message', 'createdAt'])
        && data.name is string && data.name.size() <= 150
        && data.email is string && data.email.size() <= 150
        && data.phone is string && data.phone.size() <= 30
        && data.message is string && data.message.size() <= 5000
        && data.createdAt is string && data.createdAt.size() <= 50;
      }
    }
  }
}
